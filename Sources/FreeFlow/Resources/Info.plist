<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.freeflow.app</string>
    <key>CFBundleName</key>
    <string>FreeFlow</string>
    <key>CFBundleDisplayName</key>
    <string>Free Flow</string>
    <key>CFBundleExecutable</key>
    <string>FreeFlow</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>Free Flow needs microphone access to record your voice for on-device transcription.</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Sparkle auto-update (planning 0009). The appcast is published to each
         GitHub Release by the release workflow; /releases/latest/download/ always
         resolves to the newest non-prerelease release's asset, so an installed
         copy learns about newer versions without a separate host. -->
    <key>SUFeedURL</key>
    <string>https://github.com/abgregs/freeflow/releases/latest/download/appcast.xml</string>
    <!-- Sparkle EdDSA public key. PLACEHOLDER — the MAINTAINER generates the
         keypair once with Sparkle's `generate_keys`, pastes the printed public
         key here, and stores the private key as the `SPARKLE_PRIVATE_KEY` CI
         secret. See docs/architecture/release-pipeline.md. Auto-update stays
         inert (updates fail signature verification) until this is real. Never
         commit the private key. -->
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_SPARKLE_ED_PUBLIC_KEY</string>
</dict>
</plist>
